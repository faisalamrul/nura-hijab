---
---

<!-- Newsletter -->
<section class="bg-jet text-white py-24 px-6 md:px-10">
  <div class="max-w-md mx-auto text-center">
    <h2 class="font-heading font-light text-[1.9rem] mb-3">Jadi yang Pertama Tahu</h2>
    <p class="text-silver text-sm mb-10 leading-relaxed">
      Notifikasi koleksi terbaru, behind-the-scene, dan penawaran eksklusif.
    </p>
    <div class="flex">
      <input
        type="email"
        placeholder="Email kamu"
        class="flex-1 bg-transparent border border-white/20 px-5 py-3 text-sm text-white placeholder:text-white/30 focus:outline-none focus:border-white/50 transition-colors min-w-0"
      />
      <button class="bg-white text-jet px-8 py-3 text-[11px] tracking-[0.22em] uppercase font-medium hover:bg-zinc-100 transition-colors shrink-0">
        Daftar
      </button>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="bg-jet border-t border-white/[0.06] py-16 px-6 md:px-10">
  <div class="max-w-[1440px] mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-14">

      <div class="col-span-2 md:col-span-1">
        <p class="font-heading text-white text-[1.35rem] tracking-[0.4em] font-light mb-4">NURA</p>
        <p class="text-white/35 text-xs leading-relaxed max-w-[180px]">
          Label hijab editorial dari Jakarta untuk perempuan modern Indonesia.
        </p>
      </div>

      <div>
        <p class="text-white/25 text-[10px] tracking-[0.3em] uppercase mb-5">Koleksi</p>
        <ul class="space-y-3">
          <li><a href="/koleksi/voal/" class="text-white/50 text-sm hover:text-white transition-colors duration-200">Voal Series</a></li>
          <li><a href="/koleksi/ceruti/" class="text-white/50 text-sm hover:text-white transition-colors duration-200">Ceruti Series</a></li>
          <li><a href="/koleksi/segi-empat/" class="text-white/50 text-sm hover:text-white transition-colors duration-200">Segi Empat</a></li>
          <li><a href="/koleksi/pashmina/" class="text-white/50 text-sm hover:text-white transition-colors duration-200">Pashmina</a></li>
        </ul>
      </div>

      <div>
        <p class="text-white/25 text-[10px] tracking-[0.3em] uppercase mb-5">Bantuan</p>
        <ul class="space-y-3">
          <li><a href="/tentang/" class="text-white/50 text-sm hover:text-white transition-colors duration-200">Tentang NURA</a></li>
          <li><a href="/pengiriman/" class="text-white/50 text-sm hover:text-white transition-colors duration-200">Pengiriman</a></li>
          <li><a href="/pengembalian/" class="text-white/50 text-sm hover:text-white transition-colors duration-200">Retur & Penukaran</a></li>
          <li><a href="/faq/" class="text-white/50 text-sm hover:text-white transition-colors duration-200">FAQ</a></li>
        </ul>
      </div>

      <div>
        <p class="text-white/25 text-[10px] tracking-[0.3em] uppercase mb-5">Ikuti Kami</p>
        <ul class="space-y-3">
          {["Instagram", "TikTok", "Pinterest"].map((l) => (
            <li>
              <a href="#" class="text-white/50 text-sm hover:text-white transition-colors duration-200">{l}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-white/[0.06] pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/25 text-xs">© 2026 NURA. Semua hak dilindungi.</p>
      <div class="flex gap-8">
        <a href="#" class="text-white/25 text-xs hover:text-white/50 transition-colors">Kebijakan Privasi</a>
        <a href="#" class="text-white/25 text-xs hover:text-white/50 transition-colors">Syarat & Ketentuan</a>
      </div>
    </div>
  </div>
</footer>
