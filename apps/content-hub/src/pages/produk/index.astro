---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SchemaOrg from "../../components/SchemaOrg.astro";
import NavHeader from "../../components/NavHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { ProductGrid } from "../../components/ProductGrid";

const allProducts = await getCollection("products");

const products = allProducts.map((p) => ({
  id: p.id,
  name: p.data.name,
  price: p.data.price,
  variants: p.data.variants,
  image: p.data.image,
  badge: p.data.badge,
  material: p.data.material,
  tag: p.data.tag,
  inStock: p.data.inStock,
}));

const siteUrl = (Astro.site ?? new URL("http://localhost:4321")).toString().replace(/\/$/, "");
const pageUrl = `${siteUrl}/produk/`;

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Semua Produk Hijab NURA",
  "numberOfItems": products.length,
  "itemListElement": products.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${siteUrl}/produk/${p.id}/`,
    "name": p.name,
  })),
};

const materials = [...new Set(allProducts.map((p) => p.data.material).filter(Boolean))];
---

<Layout
  title="Koleksi Hijab Premium — NURA"
  description={`Temukan semua ${products.length} produk hijab premium NURA — voal, ceruti, segi empat, pashmina, jersey, dan sifon. Filter kategori dan urutkan sesuai preferensi.`}
  canonical={pageUrl}
>
  <SchemaOrg slot="head" schema={itemListSchema} />

  <NavHeader />
  <Breadcrumb items={[
    { label: "Beranda", href: "/" },
    { label: "Koleksi" },
  ]} />

  <main>

    <!-- ── Editorial Header ─────────────────────────────── -->
    

    <!-- ── Divider line ──────────────────────────────────── -->
    <div class="max-w-[1440px] mx-auto px-6 md:px-10">
      <div class="border-t border-zinc-100"></div>
    </div>

    <!-- ── Product Grid ──────────────────────────────────── -->
    <div class="max-w-[1440px] mx-auto px-6 md:px-10 py-12 md:py-16">
      <ProductGrid client:visible products={products} />
    </div>

    <!-- ── Bottom CTA ────────────────────────────────────── -->
    <section class="border-t border-zinc-100 mt-8">
      <div class="max-w-[1440px] mx-auto px-6 md:px-10 py-16 md:py-20 grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-[10px] tracking-[0.35em] uppercase text-muted mb-4">Tidak yakin memilih?</p>
          <p class="font-heading font-light text-ink text-[1.5rem] md:text-[1.9rem] leading-snug">
            Pelajari perbedaan tiap material di NURA Magazine.
          </p>
        </div>
        <div class="md:text-right">
          <a
            href="/artikel/"
            class="inline-flex items-center gap-3 text-[10.5px] tracking-[0.2em] uppercase text-ink border-b border-ink pb-0.5 hover:text-muted hover:border-muted transition-colors duration-200"
          >
            Baca Style Guide
            <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

  </main>

  <SiteFooter />
</Layout>
