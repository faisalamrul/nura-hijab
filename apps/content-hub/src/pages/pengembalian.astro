---
import Layout from "../layouts/Layout.astro";
import NavHeader from "../components/NavHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Breadcrumb from "../components/Breadcrumb.astro";

const siteUrl = (Astro.site ?? new URL("http://localhost:4321")).toString().replace(/\/$/, "");
const pageUrl = `${siteUrl}/pengembalian/`;
---

<Layout
  title="Kebijakan Pengembalian & Penukaran — NURA"
  description="Kebijakan pengembalian dan penukaran produk NURA. Return dalam 7 hari, produk cacat diganti gratis, proses mudah dan transparan. Kepuasan pelanggan adalah prioritas kami."
  canonical={pageUrl}
>
  <NavHeader />
  <Breadcrumb items={[
    { label: "Beranda", href: "/" },
    { label: "Pengembalian & Penukaran" },
  ]} />

  <main class="max-w-[1440px] mx-auto px-6 md:px-10 py-16 md:py-20">
    <div class="max-w-3xl">

      <p class="text-[10px] tracking-[0.35em] uppercase text-muted mb-3">Kebijakan</p>
      <h1 class="font-heading font-light text-ink text-[2.2rem] md:text-[3rem] leading-tight mb-4">
        Pengembalian & Penukaran
      </h1>
      <p class="text-sm text-muted leading-relaxed mb-16 max-w-xl">
        Kepuasan kamu adalah prioritas kami. Jika ada yang tidak sesuai, kami siap membantu dengan proses yang mudah dan transparan.
      </p>

      <!-- Jaminan -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        {[
          { label: "7 Hari", desc: "Window waktu pengembalian setelah produk diterima" },
          { label: "Gratis", desc: "Biaya pengiriman pengembalian untuk produk cacat atau salah kirim" },
          { label: "100%", desc: "Pengembalian dana atau penukaran produk tanpa pertanyaan untuk kasus yang memenuhi syarat" },
        ].map(({ label, desc }) => (
          <div class="border-t-2 border-jet pt-6">
            <p class="font-heading font-light text-ink text-3xl mb-2">{label}</p>
            <p class="text-sm text-muted leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>

      <!-- Alasan yang diterima -->
      <section class="mb-16">
        <h2 class="font-heading font-light text-ink text-xl mb-6">Alasan Pengembalian yang Diterima</h2>
        <div class="space-y-3">
          {[
            "Produk memiliki cacat produksi (jahitan lepas, warna tidak merata, lubang)",
            "Produk yang diterima tidak sesuai dengan deskripsi atau foto di website",
            "Produk yang dikirim adalah item yang salah (model atau warna berbeda dari yang dipesan)",
            "Produk rusak akibat proses pengiriman",
            "Ukuran tidak sesuai (hanya untuk penukaran, bukan pengembalian dana)",
          ].map((item) => (
            <div class="flex gap-3 text-sm text-muted">
              <span class="text-ink mt-0.5 shrink-0">✓</span>
              <span class="leading-relaxed">{item}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- Alasan yang tidak diterima -->
      <section class="mb-16">
        <h2 class="font-heading font-light text-ink text-xl mb-6">Alasan yang Tidak Dapat Diproses</h2>
        <div class="space-y-3">
          {[
            "Produk sudah dipakai (meski hanya sekali)",
            "Tag/label produk sudah dilepas",
            "Kemasan asli NURA sudah dibuang atau rusak",
            "Permintaan pengembalian lebih dari 7 hari setelah produk diterima",
            "Perubahan preferensi pribadi (tidak suka warna setelah melihat langsung)",
            "Produk yang dibeli dalam program sale atau flash sale (kecuali cacat produksi)",
          ].map((item) => (
            <div class="flex gap-3 text-sm text-muted">
              <span class="text-red-400 mt-0.5 shrink-0">✕</span>
              <span class="leading-relaxed">{item}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- Cara mengajukan -->
      <section class="mb-16">
        <h2 class="font-heading font-light text-ink text-xl mb-8">Cara Mengajukan Pengembalian</h2>
        <div class="space-y-6">
          {[
            {
              step: "01",
              title: "Hubungi Customer Service",
              desc: "Kirim pesan ke WhatsApp atau Instagram @nura.id dalam 7 hari setelah produk diterima. Sertakan nomor pesanan dan alasan pengembalian.",
            },
            {
              step: "02",
              title: "Dokumentasi Produk",
              desc: "Foto produk yang bermasalah dari berbagai sudut (termasuk close-up area cacat, tag yang masih terpasang, dan kemasan). Kirimkan foto ke tim kami untuk verifikasi.",
            },
            {
              step: "03",
              title: "Persetujuan Pengembalian",
              desc: "Tim kami akan memverifikasi kelayakan pengembalian dalam 1-2 hari kerja. Kamu akan menerima konfirmasi beserta instruksi pengiriman balik.",
            },
            {
              step: "04",
              title: "Kirim Produk",
              desc: "Kemas produk dengan aman menggunakan kemasan asli NURA. Untuk kasus cacat atau salah kirim, biaya pengiriman ditanggung NURA (label pengiriman akan dikirimkan).",
            },
            {
              step: "05",
              title: "Proses Penggantian",
              desc: "Setelah produk diterima dan diverifikasi oleh tim kami, proses penukaran atau pengembalian dana akan dilakukan dalam 3-5 hari kerja.",
            },
          ].map(({ step, title, desc }) => (
            <div class="flex gap-6">
              <span class="text-[10px] tracking-[0.2em] text-muted/50 font-mono shrink-0 pt-0.5">{step}</span>
              <div>
                <h3 class="text-[13px] font-medium text-ink mb-1">{title}</h3>
                <p class="text-sm text-muted leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Pengembalian dana -->
      <section class="mb-16">
        <h2 class="font-heading font-light text-ink text-xl mb-6">Pengembalian Dana (Refund)</h2>
        <p class="text-sm text-muted leading-relaxed mb-4">
          Pengembalian dana diproses ke metode pembayaran asli dalam 3-7 hari kerja setelah produk diterima dan diverifikasi:
        </p>
        <ul class="space-y-2 text-sm text-muted">
          <li>· <strong class="text-ink">Transfer Bank:</strong> 1-3 hari kerja</li>
          <li>· <strong class="text-ink">GoPay / OVO / Dana:</strong> 1-2 hari kerja</li>
          <li>· <strong class="text-ink">Kartu Kredit:</strong> 5-7 hari kerja (tergantung kebijakan bank)</li>
          <li>· <strong class="text-ink">COD:</strong> Transfer bank dalam 3 hari kerja (rekening atas nama pemesan)</li>
        </ul>
      </section>

      <!-- Contact -->
      <section class="border-t border-zinc-100 pt-10">
        <p class="text-[10px] tracking-[0.3em] uppercase text-muted mb-3">Butuh Bantuan?</p>
        <p class="text-sm text-muted leading-relaxed mb-6 max-w-md">
          Tim customer service kami siap membantu proses pengembalian kamu Senin–Sabtu, 09.00–17.00 WIB.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="https://instagram.com/nura.id"
            class="inline-flex items-center gap-3 text-[11px] tracking-[0.2em] uppercase text-ink border-b border-ink pb-0.5 hover:text-muted hover:border-muted transition-colors duration-200"
          >
            Instagram @nura.id
          </a>
          <a
            href="/faq/"
            class="inline-flex items-center gap-3 text-[11px] tracking-[0.2em] uppercase text-muted border-b border-muted pb-0.5 hover:text-ink hover:border-ink transition-colors duration-200"
          >
            Lihat FAQ
          </a>
        </div>
      </section>

    </div>
  </main>

  <SiteFooter />
</Layout>
